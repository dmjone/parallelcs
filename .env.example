# ParallelCS environment configuration.
# Copy to `.env` for local runs. On Cloud Run these are set via --set-env-vars.
# No API keys: Vertex AI and GCS authenticate via ADC / the attached service account.

# HTTP port. Cloud Run injects this automatically; only set it locally.
PORT=8080

# GCS bucket holding curriculum + state objects. Required. No gs:// prefix.
CONTENT_BUCKET=parallelcs-content-example

# GCP project id. Required.
GCP_PROJECT=dmjone-example

# Vertex AI location for Gemini calls.
VERTEX_LOCATION=global

# Gemini model id.
GEMINI_MODEL=gemini-2.5-flash

# development | test | production
NODE_ENV=development
