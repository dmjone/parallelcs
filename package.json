{
  "name": "parallelcs",
  "version": "1.0.0",
  "private": true,
  "description": "ParallelCS: AI-native, product-centric CS curriculum track. Self-updating single Cloud Run service.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --watch src/server.mjs",
    "test:resilience": "node test/update-resilience.mjs",
    "sync-seed": "node scripts/sync-seed.mjs",
    "check:seed": "node scripts/check-seed-freshness.mjs",
    "lint": "eslint .",
    "typecheck": "find src test scripts -name \"*.mjs\" -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.16.0",
    "@google/genai": "^1.0.0",
    "fastify": "^5.2.0",
    "zod": "^3.24.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}
